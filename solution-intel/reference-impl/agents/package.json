{
  "name": "@solution-intelligence/agents",
  "version": "0.2.0-pre",
  "description": "Pure-read agents that walk a Solution Intelligence Graph (SIG) and emit reports. CompletenessAgent surfaces hypothesis/contract gaps; BookendAuditAgent diffs SIG-regenerated right-bookend snapshots against committed files.",
  "author": "William Fredricks",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/wfredricks/archetypes.git",
    "directory": "solution-intel/reference-impl/agents"
  },
  "keywords": [
    "solution-intelligence",
    "agents",
    "completeness",
    "bookend",
    "audit",
    "sig",
    "neo4j",
    "archetype",
    "typescript"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "LICENSE", "README.md", "CHANGELOG.md"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@solution-intelligence/contract-loader": "file:../contract-loader",
    "neo4j-driver": "^5.27.0",
    "polygraph-db": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
