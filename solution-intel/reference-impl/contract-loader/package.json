{
  "name": "@solution-intelligence/contract-loader",
  "version": "0.1.0-pre",
  "description": "Parses LEFT-BOOKEND.md files into graph payloads and commits archetype contracts to PolyGraph anchored to a Solution root. Reference implementation of the solution-intel archetype.",
  "author": "William Fredricks",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/wfredricks/archetypes.git",
    "directory": "solution-intel/reference-impl/contract-loader"
  },
  "keywords": [
    "solution-intelligence",
    "contract-loader",
    "sig",
    "solution-intelligence-graph",
    "archetype",
    "contract",
    "bookend",
    "polygraph",
    "neo4j",
    "typescript"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "LICENSE", "README.md", "CHANGELOG.md"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "neo4j-driver": "^5.27.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
