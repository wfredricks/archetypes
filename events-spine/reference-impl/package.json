{
  "name": "@solution-intelligence/events-spine-reference",
  "version": "0.1.0-pre",
  "private": true,
  "description": "TypeScript reference implementation for the events-spine composite archetype (publisher + subscriber + Scribe + MCP server). Not published; adopted by reference.",
  "author": "William Fredricks",
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests examples",
    "lint:fix": "eslint src tests examples --fix",
    "format": "prettier --write src tests examples",
    "format:check": "prettier --check src tests examples",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "nats": "^2.28.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
